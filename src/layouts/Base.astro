---
import '../styles/global.css'
import { MuskaaanLogo } from '../components/MuskaaanLogo'
import { ThemeToggle } from '../components/ThemeToggle'

export interface Props {
  title?: string
  description?: string
}

const {
  title = 'müskaan',
  description = 'AI-powered healthcare practice management platform. Transcribe consultations, analyse imaging, and generate clinical notes in real time.',
} = Astro.props
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <!-- Fonts: Manrope (body), Quicksand + Dosis (logo), Noto Sans Devanagari (watermark) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Quicksand:wght@400;500&family=Dosis:wght@500&family=Noto+Sans+Devanagari:wght@600&display=swap"
      rel="stylesheet"
    />
    <!-- Prevent theme flash -->
    <script is:inline>
      const t = localStorage.getItem('theme') || 'dark'
      document.documentElement.classList.toggle('dark', t === 'dark')
      document.documentElement.classList.toggle('light', t === 'light')
    </script>
  </head>

  <body class="min-h-screen flex flex-col bg-white dark:bg-[#07090F] text-slate-900 dark:text-white overflow-x-hidden transition-colors duration-300">

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-slate-200 dark:border-white/[0.06] bg-white/90 dark:bg-[#07090F]/80 backdrop-blur-xl px-6">
      <div class="max-w-6xl mx-auto h-16 flex items-center justify-between">
        <a href="/">
          <MuskaaanLogo height={36} className="text-[#112754] dark:text-white" />
        </a>
        <ThemeToggle client:load />
      </div>
    </nav>

    <!-- Page content -->
    <main class="flex-1 flex flex-col pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="relative border-t border-slate-200 dark:border-white/[0.05] py-8 px-6">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand-accent/40 to-transparent"></div>
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <MuskaaanLogo height={22} className="text-[#112754]/70 dark:text-white/40" />
        <p class="text-xs text-slate-300 dark:text-white/15">© {new Date().getFullYear()} Müskaan</p>
      </div>
    </footer>

  </body>
</html>