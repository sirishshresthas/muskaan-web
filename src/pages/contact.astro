---
import Base from '../layouts/Base.astro'
import { ContactForm } from '../components/ContactForm'
---

<Base title="Contact — müskaan" description="Tell us about your practice. We'll be in touch.">
  <div class="relative flex-1 flex flex-col px-6 pt-16 overflow-hidden">

    <!-- Glow -->
    <div class="absolute inset-0 pointer-events-none hidden dark:block">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[500px] bg-brand-primary/30 rounded-full blur-[130px]"></div>
    </div>
    <div class="absolute inset-0 pointer-events-none dark:hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[400px] bg-gradient-to-b from-brand-primary/[0.04] to-transparent"></div>
    </div>

    <div class="relative z-10 flex-1 flex flex-col items-center justify-center w-full max-w-lg mx-auto py-12">
      <ContactForm client:load />
    </div>

  </div>
</Base>